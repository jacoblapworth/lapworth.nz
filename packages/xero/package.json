{
  "name": "@lapworth/xero",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./examples": {
      "types": "./dist/examples/index.d.ts",
      "import": "./dist/examples/index.js"
    },
    "./styles.css": "./.styled/styles.css"
  },
  "scripts": {
    "build": "NODE_OPTIONS=\"--max-old-space-size=8024\" tsdown",
    "build:storybook": "storybook build --webpack-stats-json",
    "chromatic": "chromatic --build-script-name=build:storybook",
    "css": "panda cssgen",
    "css:watch": "panda cssgen --watch",
    "dev": "tsdown --watch ./src --no-clean",
    "format": "biome check --write",
    "storybook": "storybook dev -p 6007 --no-open",
    "test": "vitest",
    "tokens": "panda codegen",
    "tokens:watch": "panda codegen --watch",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
    "@ariakit/react": "catalog:",
    "@faker-js/faker": "10.4.0",
    "@gsap/react": "2.1.2",
    "@number-flow/react": "0.6.0",
    "@tanstack/react-table": "8.21.3",
    "date-fns": "4.1.0",
    "gsap": "3.14.2",
    "lucide-react": "1.7.0",
    "motion": "12.38.0",
    "next": "catalog:",
    "next-intl": "4.8.4",
    "nuqs": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-error-boundary": "6.1.1",
    "web": "0.0.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@chromatic-com/storybook": "^5.1.1",
    "@pandacss/dev": "1.9.1",
    "@pandacss/studio": "1.9.1",
    "@pandacss/types": "1.9.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/nextjs-vite": "^10.3.3",
    "@total-typescript/ts-reset": "0.6.1",
    "@total-typescript/tsconfig": "1.0.4",
    "@types/node": "25.5.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "4.1.2",
    "@vitest/coverage-v8": "4.1.2",
    "chromatic": "16.1.0",
    "playwright": "^1.59.1",
    "rollup-plugin-preserve-directives": "0.4.0",
    "rollup-plugin-preserve-use-client": "3.0.1",
    "storybook": "^10.3.3",
    "storybook-next-intl": "10.1.1",
    "tsdown": "0.21.7",
    "typescript": "catalog:",
