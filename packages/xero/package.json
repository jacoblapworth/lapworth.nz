{
  "name": "@lapworth/xero",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./examples": {
      "types": "./dist/examples/index.d.ts",
      "import": "./dist/examples/index.js"
    },
    "./styles.css": "./.styled/styles.css"
  },
  "scripts": {
    "build": "NODE_OPTIONS=\"--max-old-space-size=8024\" tsdown",
    "build:storybook": "storybook build",
    "chromatic": "chromatic --build-script-name=build:storybook",
    "css": "panda cssgen",
    "css:watch": "panda cssgen --watch",
    "dev": "NODE_OPTIONS=\"--max-old-space-size=8024\" tsdown --watch ./src --no-clean",
    "format": "biome check --write",
    "storybook": "storybook dev -p 6007 --no-open",
    "test": "vitest",
    "tokens": "panda codegen",
    "tokens:watch": "panda codegen --watch",
    "types:check": "tsc --noEmit"
  },
  "dependencies": {
